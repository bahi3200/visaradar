SUPABASE_URL=https://frhrvkzkihxaopnsznrj.supabase.co
WORKER_TOKEN=paste-token-from-admin-ui-here
INTERVAL_MINUTES=5
TARGETS_JSON=[{"country_code":"FR","provider":"vfs","url":"https://visa.vfsglobal.com/dza/fr/fra"},{"country_code":"DE","provider":"tls","url":"https://visas-de.tlscontact.com/visa/dz"}]

# Decodo Residential Rotating Proxy (optional but recommended)
# Single rotating gateway:
DECODO_PROXY=http://USER:PASS@gate.decodo.com:7000
# Multiple sticky sessions (round-robin per scan):
# DECODO_PROXY=http://USER-session-1:PASS@gate.decodo.com:7000,http://USER-session-2:PASS@gate.decodo.com:7000

# === Advanced anti-bot evasion ===
# Probability (0..1) of running headful (visible) Chromium instead of headless.
HEADFUL_PROBABILITY=0.15
# Comma list of provider-specific proxy pools, e.g. vfs=http://...,tls=http://...
# Falls back to DECODO_PROXY if a provider has none.
PROVIDER_PROXY_POOLS=
# Min/Max scan jitter percentage (random ± around INTERVAL_MINUTES).
SCAN_JITTER_PCT=35